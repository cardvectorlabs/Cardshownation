# Primary Prisma connection string used by the web app.
DATABASE_URL="postgresql://postgres:replace-me@db.your-project.supabase.co:5432/postgres"

# Direct database connection for migrations or admin operations.
DIRECT_URL="postgresql://postgres:replace-me@db.your-project.supabase.co:5432/postgres"

# Public base URL for the Next.js app.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# One-time bootstrap code used to create the first admin account at /admin/setup.
ADMIN_SETUP_CODE="replace-me"

# Secret used to sign admin session cookies.
ADMIN_SESSION_SECRET="replace-me"

# Password that gates access to admin-only routes.
ADMIN_PASSWORD="replace-me"

# Secret used to sign promoter portal session cookies.
PROMOTER_SESSION_SECRET="replace-me"

# Shared secret used to authenticate scheduled job requests.
CRON_SECRET="replace-me"

# Vercel Blob token required in production for durable flyer uploads.
BLOB_READ_WRITE_TOKEN="replace-me"
